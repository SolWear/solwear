{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "solwear_st",
  "version": "0.1.0",
  "identifier": "com.solwear.service-tool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "solwear_st",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
